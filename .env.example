# ═══════════════════════════════════════════════════════════════
# AI Voice Calling Agent — Environment Variables
# ═══════════════════════════════════════════════════════════════
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values below
#   3. NEVER commit your .env file to GitHub
#      (it is already listed in .gitignore)
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────
# STT — Groq Whisper API
# ───────────────────────────────────────────────────────────────
# Free key at: https://console.groq.com
# Steps: Sign up → API Keys → Create API Key
# Key starts with: gsk_
# Free tier: 2,000 requests/day · 8 hours audio/day
# ───────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ───────────────────────────────────────────────────────────────
# LLM — Google Gemini Flash
# ───────────────────────────────────────────────────────────────
# Free key at: https://aistudio.google.com
# Steps: Sign in with Google → Get API Key → Create API Key
# Key starts with: AIza
# Free tier: 1,500 requests/day · 1M token context
# ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ───────────────────────────────────────────────────────────────
# Telephony — Twilio
# ───────────────────────────────────────────────────────────────
# Sign up at: https://twilio.com ($15 free trial credit)
# Steps:
#   1. Sign up → verify your phone number
#   2. Console Dashboard → copy Account SID and Auth Token
#   3. Phone Numbers → Buy a number (Voice capability)
#
# IMPORTANT (trial accounts):
#   - Can only call VERIFIED numbers
#   - Add numbers at: Console → Verified Caller IDs
# ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx


# ───────────────────────────────────────────────────────────────
# Database — PostgreSQL on Supabase
# ───────────────────────────────────────────────────────────────
# Free at: https://supabase.com (500MB free)
# Steps:
#   1. Create project → set a password → region: Asia (Singapore)
#   2. Project Settings → Database → "Session pooler" tab
#   3. Copy the connection string
#   4. Replace [YOUR-PASSWORD] with your actual password
#
# IMPORTANT: Use Session Pooler URL (port 6543) NOT direct (port 5432)
# Username format MUST be: postgres.YOURPROJECTREF
# ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.YOURPROJECTREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres


# ───────────────────────────────────────────────────────────────
# Tunnel — ngrok
# ───────────────────────────────────────────────────────────────
# Free at: https://ngrok.com
# Steps:
#   1. Sign up → copy your authtoken
#   2. Run: ngrok config add-authtoken YOUR_TOKEN
#   3. Run: ngrok http 8000
#   4. Copy the https://xxxx.ngrok-free.app URL here
#
# UPDATE THIS every time ngrok restarts (free plan gives new URL)
# Used by Twilio to reach your local server
# ───────────────────────────────────────────────────────────────
NGROK_URL=https://xxxx.ngrok-free.app


# ───────────────────────────────────────────────────────────────
# Campaign / Company Settings
# ───────────────────────────────────────────────────────────────
# Used in the agent's greeting and conversations
# Edit these to match your business
# ───────────────────────────────────────────────────────────────
COMPANY_NAME=Your Company Name
PROJECT_NAME=Your Project Name
AGENT_NAME=Priya
SALES_PHONE=+91xxxxxxxxxx


# ───────────────────────────────────────────────────────────────
# Optional — Backup Gemini API Key
# ───────────────────────────────────────────────────────────────
# If your main Gemini key hits the daily rate limit,
# the agent will automatically switch to this backup key.
# Get a second free key using a different Google account.
# Leave blank if not using a backup.
# ───────────────────────────────────────────────────────────────
GEMINI_API_KEY_BACKUP=


# ───────────────────────────────────────────────────────────────
# Quick Reference — where each key is used
# ───────────────────────────────────────────────────────────────
# GROQ_API_KEY        → app/stt.py       (Whisper transcription)
# GEMINI_API_KEY      → app/llm.py       (LLM responses)
#                     → app/extractor.py (CRM data extraction)
# TWILIO_*            → app/main.py      (inbound webhook)
#                     → make_call.py     (outbound calls)
# DATABASE_URL        → app/database.py  (PostgreSQL logging)
# NGROK_URL           → make_call.py     (webhook URL for Twilio)
#                     → app/main.py      (outbound call webhook)
# COMPANY_NAME etc.   → app/call_handler.py (personalized greeting)
# ───────────────────────────────────────────────────────────────
